@page
@model TestingProlect.Pages.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тестирования</title>
    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            font-family: 'Inter', -apple-system, sans-serif; 
            background-color: var(--bg);
            background-image: radial-gradient(at 0% 0%, hsla(220, 30%, 15%, 1) 0, transparent 50%), 
                              radial-gradient(at 50% 0%, hsla(220, 40%, 25%, 1) 0, transparent 50%);
            min-height: 100vh; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            padding: 20px; 
            color: var(--text-main);
        }

        .container { 
            background: var(--card-bg); 
            border-radius: 24px; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            padding: 40px; 
            width: 100%; 
            max-width: 600px;
            transition: all 0.3s ease;
        }

        .header h1 { font-size: 28px; text-align: center; margin-bottom: 24px; font-weight: 800; }
        
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; }
        .form-group input, .form-group select { 
            width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 12px; font-size: 16px; outline: none;
        }
        .form-group input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1); }

        .btn { 
            padding: 14px 24px; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; 
            transition: all 0.2s; display: block; width: 100%; text-align: center; text-decoration: none;
            font-size: 16px; margin-top: 10px;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-hover); }
        .btn-secondary { background: #f1f5f9; color: #475569; }
        .btn-danger { background: #fee2e2; color: #dc2626; }

        .test-item {
            background: #f8fafc; border: 1px solid var(--border); border-radius: 16px;
            padding: 16px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center;
        }
        .test-info h4 { margin-bottom: 4px; }
        .test-info p { font-size: 13px; color: var(--text-muted); }
        .start-link { background: var(--primary); color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 600; }

        .table-container { margin-top: 20px; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; font-size: 14px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid var(--border); }
        th { background: #f8fafc; font-weight: 600; }

        .hidden { display: none !important; }
        hr { border: 0; border-top: 1px solid var(--border); margin: 24px 0; }
    </style>
</head>
<body>

    <div class="container" id="authPage">
        <div class="header"><h1>Тестирования</h1></div>
        <div class="form-group">
            <label>Ваше ФИО</label>
            <input type="text" id="fullName" placeholder="Иван Иванов">
        </div>
        <div class="form-group">
            <label>Группа / Класс</label>
            <input type="text" id="group" placeholder="11-А">
        </div>
        <div class="form-group">
            <label>Кто вы?</label>
            <select id="role">
                <option value="student">Студент</option>
                <option value="teacher">Преподаватель</option>
            </select>
        </div>
        <button class="btn btn-primary" onclick="login()">Войти в систему</button>
    </div>

    <div class="container hidden" id="studentPage">
        <div class="header"><h1>Личный кабинет</h1></div>
        <div style="background: #eff6ff; padding: 15px; border-radius: 12px; margin-bottom: 20px;">
            <p>Студент: <strong id="studentName"></strong></p>
            <p>Группа: <strong id="studentGroup"></strong></p>
        </div>
        
        <h3>Доступные тесты</h3>
        <div style="margin-top: 15px;">
            @if(Model.AvailableTests.Any()) {
                @foreach(var test in Model.AvailableTests) {
                    <div class="test-item">
                        <div class="test-info">
                            <h4>@test.Title</h4>
                            <p>@test.Description</p>
                        </div>
                        <a href="/TakeTest/@test.Id" class="start-link">Начать</a>
                    </div>
                }
            } else {
                <p style="text-align: center; color: var(--text-muted); padding: 20px;">Тестов пока нет...</p>
            }
        </div>
        <button class="btn btn-secondary" onclick="logout()" style="margin-top: 20px;">Выйти</button>
    </div>

    <div class="container hidden" id="teacherPage" style="max-width: 800px;">
        <div class="header"><h1>Панель управления</h1></div>
        
        <a href="/CreateTest" class="btn btn-primary">➕ Создать новый тест</a>

        <div class="table-container">
            <table>
                <thead>
                    <tr><th>Студент</th><th>Группа</th><th>Результат</th><th>Дата</th></tr>
                </thead>
                <tbody>
                    @foreach(var res in Model.AllResults) {
                        <tr>
                            <td>@res.StudentName</td>
                            <td>@res.GroupName</td>
                            <td><strong>@res.Score</strong> / @res.TotalQuestions</td>
                            <td>@res.TestDate.ToString("dd.MM HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-danger" onclick="logout()" style="margin-top: 20px;">Выйти из системы</button>
    </div>

    <script>
        // При загрузке проверяем, был ли вход
        window.onload = function() {
            const savedRole = localStorage.getItem('userRole');
            if (savedRole) {
                showPage(savedRole);
            }
        };

        function login() {
            const name = document.getElementById('fullName').value;
            const group = document.getElementById('group').value;
            const role = document.getElementById('role').value;

            if (!name || !group) return alert('Пожалуйста, заполните все поля');

            // Сохраняем данные, чтобы они не пропадали при переходе на тест
            localStorage.setItem('userName', name);
            localStorage.setItem('userGroup', group);
            localStorage.setItem('userRole', role);

            showPage(role);
        }

        function showPage(role) {
            document.getElementById('authPage').classList.add('hidden');
            if (role === 'teacher') {
                document.getElementById('teacherPage').classList.remove('hidden');
            } else {
                document.getElementById('studentPage').classList.remove('hidden');
                document.getElementById('studentName').textContent = localStorage.getItem('userName');
                document.getElementById('studentGroup').textContent = localStorage.getItem('userGroup');
            }
        }

        function logout() {
            localStorage.clear();
            location.reload();
        }
    </script>
</body>
</html>
