@page
@model TestingProlect.Pages.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Информационная система тестирования</title>
    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg);
            background-image: radial-gradient(at 0% 0%, hsla(220, 30%, 15%, 1) 0, transparent 50%), 
                              radial-gradient(at 50% 0%, hsla(220, 40%, 25%, 1) 0, transparent 50%);
            min-height: 100vh; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            padding: 20px; 
        }

        .container { 
            background: var(--card-bg); 
            border-radius: 24px; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            padding: 40px; 
            width: 100%; 
            max-width: 600px;
        }

        .header h1 { color: var(--text-main); font-size: 26px; text-align: center; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: 600; }
        .form-group input, .form-group select { 
            width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 12px; 
        }

        .btn { 
            padding: 14px 24px; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; 
            transition: all 0.2s; display: block; width: 100%; text-align: center; text-decoration: none;
            margin-top: 10px;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-secondary { background: #e2e8f0; color: #475569; }
        .btn-danger { background: #ef4444; color: white; }

        .table-container { margin-top: 20px; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { background: #f8fafc; }

        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div class="container" id="authPage">
        <div class="header"><h1>Вход в систему</h1></div>
        <div class="form-group">
            <label>ФИО:</label>
            <input type="text" id="fullName" placeholder="Введите имя">
        </div>
        <div class="form-group">
            <label>Группа:</label>
            <input type="text" id="group" placeholder="Например, 10А">
        </div>
        <div class="form-group">
            <label>Роль:</label>
            <select id="role">
                <option value="student">Студент</option>
                <option value="teacher">Преподаватель</option>
            </select>
        </div>
        <button class="btn btn-primary" onclick="login()">Войти</button>
    </div>

    <div class="container hidden" id="studentPage">
        <div class="header"><h1>Личный кабинет</h1></div>
        <p>Студент: <strong id="studentName"></strong></p>
        <p>Группа: <strong id="studentGroup"></strong></p>
        <hr style="margin: 20px 0;">
        <h3>Доступные тесты:</h3>
        <button class="btn btn-primary" onclick="alert('Логика запуска тестов из базы в процессе...')">Начать стандартный тест</button>
        <button class="btn btn-secondary" onclick="logout()">Выйти</button>
    </div>

    <div class="container hidden" id="teacherPage" style="max-width: 800px;">
        <div class="header"><h1>Панель преподавателя</h1></div>
        
        <div style="display: flex; gap: 10px;">
            <a href="/CreateTest" class="btn btn-primary">Создать новый тест</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr><th>Студент</th><th>Группа</th><th>Балл</th><th>Дата</th></tr>
                </thead>
                <tbody>
                    @if(Model.AllResults != null) {
                        @foreach(var res in Model.AllResults) {
                            <tr>
                                <td>@res.StudentName</td>
                                <td>@res.GroupName</td>
                                <td>@res.Score / @res.TotalQuestions</td>
                                <td>@res.TestDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-danger" onclick="logout()">Выйти</button>
    </div>

    <script>
        let currentUser = { name: '', group: '', role: '' };

        function login() {
            const name = document.getElementById('fullName').value;
            const group = document.getElementById('group').value;
            const role = document.getElementById('role').value;

            if (!name || !group) return alert('Заполните поля!');

            currentUser = { name, group, role };
            document.getElementById('authPage').classList.add('hidden');

            if (role === 'teacher') {
                document.getElementById('teacherPage').classList.remove('hidden');
            } else {
                document.getElementById('studentPage').classList.remove('hidden');
                document.getElementById('studentName').textContent = name;
                document.getElementById('studentGroup').textContent = group;
            }
        }

        function logout() { location.reload(); }
    </script>
</body>
</html>
