@page
@model TestingProlect.Pages.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Информационная система тестирования знаний</title>
    <style>
        :root {
            --primary: #2563eb;          /* Насыщенный синий */
            --primary-hover: #1d4ed8;    /* Темно-синий */
            --bg: #f8fafc;               /* Светлый фон */
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            font-family: 'Inter', system-ui, -apple-system, sans-serif; 
            background-color: var(--bg);
            background-image: radial-gradient(at 0% 0%, hsla(220, 30%, 15%, 1) 0, transparent 50%), 
                              radial-gradient(at 50% 0%, hsla(220, 40%, 25%, 1) 0, transparent 50%);
            min-height: 100vh; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            padding: 20px; 
        }

        .container { 
            background: var(--card-bg); 
            border-radius: 24px; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            padding: 40px; 
            width: 100%; 
            max-width: 550px;
            transition: transform 0.3s ease;
        }

        .header h1 { 
            color: var(--text-main); 
            font-size: 26px; 
            font-weight: 800;
            letter-spacing: -0.025em;
            margin-bottom: 8px;
            text-align: center;
        }

        .header h2 { 
            color: var(--text-muted); 
            font-size: 15px; 
            font-weight: 400;
            margin-bottom: 32px; 
            text-align: center;
        }

        .form-group label { 
            display: block; 
            margin-bottom: 8px; 
            color: var(--text-main); 
            font-weight: 600;
            font-size: 14px;
        }

        .form-group input, .form-group select { 
            width: 100%; 
            padding: 12px 16px; 
            border: 1px solid #e2e8f0; 
            border-radius: 12px; 
            font-size: 16px;
            background: #fdfdfd;
            transition: all 0.2s;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
            background: white;
        }

        .btn { 
            padding: 14px 24px; 
            border: none; 
            border-radius: 12px; 
            font-size: 16px; 
            font-weight: 600;
            cursor: pointer; 
            transition: all 0.2s; 
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin: 5px;
        }

        .btn-primary { 
            background: var(--primary); 
            color: white;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
        }
        
        .btn-primary:hover { 
            background: var(--primary-hover); 
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
        }

        .btn-secondary { background: #e2e8f0; color: #475569; }
        .btn-danger { background: #ef4444; color: white; }
        .btn-danger:hover { background: #dc2626; }

        .option { 
            padding: 16px; 
            border: 2px solid #f1f5f9; 
            border-radius: 14px; 
            cursor: pointer; 
            transition: all 0.2s;
            font-weight: 500;
            margin-bottom: 12px;
            color: var(--text-main);
        }

        .option:hover { border-color: var(--primary); background: #eff6ff; }
        .option.selected { border-color: var(--primary); background: var(--primary); color: white; }

        .progress-bar { height: 8px; background: #f1f5f9; border-radius: 10px; margin-bottom: 24px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--primary); border-radius: 10px; transition: width 0.3s; }

        .timer { text-align: center; font-size: 16px; color: #ef4444; font-weight: 700; margin-bottom: 15px; }

        .user-info { 
            border: 1px solid #e2e8f0; 
            border-radius: 16px; 
            background: #f8fafc; 
            padding: 15px;
            margin-bottom: 20px;
        }

        .table-container { overflow-x: auto; margin-top: 20px; border-radius: 12px; border: 1px solid #e2e8f0; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 14px; text-align: left; border-bottom: 1px solid #e2e8f0; font-size: 14px; }
        th { background: #f8fafc; color: var(--text-muted); font-weight: 600; }

        .hidden { display: none !important; }
    </style>
</head>
<body>
    <div class="container" id="authPage">
        <div class="header">
            <h1>Система тестирования</h1>
            <h2>Авторизация пользователя</h2>
        </div>
        <div class="form-group">
            <label>ФИО:</label>
            <input type="text" id="fullName" placeholder="Иванов Иван Иванович">
        </div>
        <div class="form-group">
            <label>Класс / Группа:</label>
            <input type="text" id="group" placeholder="10А, МБОУ СОШ №1">
        </div>
        <div class="form-group">
            <label>Ваша роль:</label>
            <select id="role">
                <option value="student">Студент</option>
                <option value="teacher">Преподаватель</option>
            </select>
        </div>
        <button class="btn btn-primary" onclick="login()" style="width: 100%;">Войти в систему</button>
    </div>

    <div class="container hidden" id="studentPage">
        <div class="header">
            <h1>Привет, <span id="studentName"></span>!</h1>
        </div>
        <div class="user-info">
            <p><strong>Группа:</strong> <span id="studentGroup"></span></p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
            <button class="btn btn-primary" onclick="startTest()">Начать тест</button>
            <button class="btn btn-secondary" onclick="logout()">Выйти</button>
        </div>
    </div>

    <div class="container hidden" id="testPage">
        <div class="header"><h1>Тестирование</h1></div>
        <div class="timer" id="timer"></div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
        <div class="question-container">
            <div id="questionNumber" style="font-weight: 600; color: var(--primary); margin-bottom: 10px;"></div>
            <div class="question-text" id="questionText" style="font-size: 18px; margin-bottom: 20px;"></div>
            <div class="options" id="options"></div>
        </div>
        <div style="display: flex; justify-content: space-between; margin-top: 20px;">
            <button class="btn btn-secondary" id="prevBtn" onclick="prevQuestion()">Назад</button>
            <button class="btn btn-primary" id="nextBtn" onclick="nextQuestion()">Далее</button>
        </div>
    </div>

    <div class="container hidden" id="resultPage">
        <div class="header"><h1>Ваш результат</h1></div>
        <div style="text-align: center; padding: 20px 0;">
            <div id="resultScore" style="font-size: 48px; font-weight: 800; color: var(--primary);"></div>
            <div id="resultPercent" style="font-size: 24px; color: #10b981; margin-bottom: 10px;"></div>
            <p id="resultMessage" style="color: var(--text-muted);"></p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
            <button class="btn btn-primary" onclick="startTest()">Повторить</button>
            <button class="btn btn-secondary" onclick="showStudentPage()">В кабинет</button>
        </div>
    </div>

    <div class="container hidden" id="teacherPage" style="max-width: 800px;">
        <div class="header">
            <h1>Панель управления</h1>
            <h2>Результаты всех студентов</h2>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr><th>Студент</th><th>Группа</th><th>Балл</th><th>%</th></tr>
                </thead>
                <tbody id="resultsTable">
                    @if(Model.AllResults != null) {
                        @foreach(var res in Model.AllResults) {
                            <tr>
                                <td>@res.StudentName</td>
                                <td>@res.GroupName</td>
                                <td>@res.Score/@res.TotalQuestions</td>
                                <td>@(Math.Round((double)res.Score / res.TotalQuestions * 100))%</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-danger" onclick="logout()" style="width: 100%; margin-top: 20px;">Выйти из панели</button>
    </div>

    <script>
        const questions = [
            { question: "Какой тег используется для самого крупного заголовка?", options: ["<head>", "<h1>", "<header>", "<title>"], correct: 1 },
            { question: "Какой тег служит для вставки изображения?", options: ["<image>", "<img>", "<pic>", "<src>"], correct: 1 },
            { question: "Какой атрибут задает адрес ссылки в теге <a>?", options: ["src", "link", "href", "url"], correct: 2 },
            { question: "Какой тег создает нумерованный список?", options: ["<ul>", "<li>", "<ol>", "<list>"], correct: 2 },
            { question: "Какой тег определяет обычный абзац текста?", options: ["<text>", "<p>", "<paragraph>", "<div>"], correct: 1 }
        ];

        let currentUser = { name: '', group: '', role: '' };
        let currentQuestion = 0;
        let userAnswers = [];
        let timerInterval;
        let timeLeft = 300;

        function login() {
            const name = document.getElementById('fullName').value.trim();
            const group = document.getElementById('group').value.trim();
            const role = document.getElementById('role').value;
            if (!name || !group) return alert('Пожалуйста, заполните все поля!');
            currentUser = { name, group, role };
            document.getElementById('authPage').classList.add('hidden');
            if (role === 'teacher') showTeacherPage(); else showStudentPage();
        }

        function logout() { location.reload(); }

        function showStudentPage() {
            document.querySelectorAll('.container').forEach(el => el.classList.add('hidden'));
            document.getElementById('studentPage').classList.remove('hidden');
            document.getElementById('studentName').textContent = currentUser.name;
            document.getElementById('studentGroup').textContent = currentUser.group;
        }

        function showTeacherPage() {
            document.querySelectorAll('.container').forEach(el => el.classList.add('hidden'));
            document.getElementById('teacherPage').classList.remove('hidden');
        }

        function startTest() {
            currentQuestion = 0;
            userAnswers = new Array(questions.length).fill(null);
            timeLeft = 300;
            document.querySelectorAll('.container').forEach(el => el.classList.add('hidden'));
            document.getElementById('testPage').classList.remove('hidden');
            startTimer();
            showQuestion();
        }

        function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                timeLeft--;
                const min = Math.floor(timeLeft / 60);
                const sec = timeLeft % 60;
                document.getElementById('timer').textContent = `Времени осталось: ${min}:${sec.toString().padStart(2, '0')}`;
                if (timeLeft <= 0) finishTest();
            }, 1000);
        }

        function showQuestion() {
            const q = questions[currentQuestion];
            document.getElementById('questionNumber').textContent = `Вопрос ${currentQuestion + 1} из ${questions.length}`;
            document.getElementById('questionText').textContent = q.question;
            const optCont = document.getElementById('options');
            optCont.innerHTML = '';
            q.options.forEach((opt, i) => {
                const div = document.createElement('div');
                div.className = 'option' + (userAnswers[currentQuestion] === i ? ' selected' : '');
                div.textContent = opt;
                div.onclick = () => { userAnswers[currentQuestion] = i; showQuestion(); };
                optCont.appendChild(div);
            });
            document.getElementById('progressFill').style.width = ((currentQuestion + 1) / questions.length * 100) + '%';
            document.getElementById('prevBtn').style.visibility = currentQuestion === 0 ? 'hidden' : 'visible';
            document.getElementById('nextBtn').textContent = currentQuestion === questions.length - 1 ? 'Завершить' : 'Далее';
        }

        function prevQuestion() { if(currentQuestion > 0) { currentQuestion--; showQuestion(); } }
        function nextQuestion() { if(currentQuestion < questions.length - 1) { currentQuestion++; showQuestion(); } else { finishTest(); } }

        async function finishTest() {
            clearInterval(timerInterval);
            let score = 0;
            questions.forEach((q, i) => { if(userAnswers[i] === q.correct) score++; });
            
            await fetch('/Index?handler=SaveResult', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    StudentName: currentUser.name,
                    GroupName: currentUser.group,
                    Score: score,
                    TotalQuestions: questions.length
                })
            });

            document.querySelectorAll('.container').forEach(el => el.classList.add('hidden'));
            document.getElementById('resultPage').classList.remove('hidden');
            document.getElementById('resultScore').textContent = `${score} / ${questions.length}`;
            const pct = Math.round(score/questions.length*100);
            document.getElementById('resultPercent').textContent = pct + '%';
            document.getElementById('resultMessage').textContent = pct >= 60 ? '🎉 Тест успешно пройден!' : '📚 Нужно еще подучить';
        }
    </script>
</body>
</html>
