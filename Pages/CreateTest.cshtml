@page
@model CreateTestModel
@{
    ViewData["Title"] = "Создание теста";
}

<h2>Создать новый тест</h2>

<form method="post">
    <div class="form-group">
        <label>Название теста</label>
        <input name="TestName" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Описание</label>
        <textarea name="Description" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Сохранить и перейти к вопросам</button>
</form>
